{
  "manifest_version": 3,
  "name": "MD to Word/PDF Converter",
  "version": "1.0.0",
  "description": "Convert Markdown to Word or PDF with live preview",
  "permissions": ["downloads", "storage"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["preview/preview.html", "css/markdown.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
